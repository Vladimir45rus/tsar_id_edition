# Пример переменных окружения для Царь-ID (Flutter / flutter_dotenv).
# Скопируйте в файл `.env` в корне проекта (он подключён в pubspec как asset).

# --- SMS-провайдер (Twilio / SMS.ru / свой бэкенд) ---
# URL вашего API, который отправляет SMS с кодом.
SMS_API_BASE_URL=https://api.example.com/sms

# Ключ API (НЕ коммитьте реальные значения в git).
SMS_API_KEY=your_api_key_here

# Идентификатор отправителя / шаблон (зависит от провайдера).
SMS_SENDER_ID=TsarID

# --- Облако / синхронизация (если появится серверный слой) ---
CLOUD_SYNC_ENDPOINT=https://sync.example.com/v1
CLOUD_CLIENT_ID=your_oauth_client_id

# Примечание: расшифровка бэкапа .tsarbackup выполняется только на устройстве;
# эти ключи не участвуют в криптографии архива.
